# Maintainer: Tarun Vishwakarma <tarunvishwakarma81@gmail.com>
pkgname=netspd
pkgver=0.1.4
pkgrel=1
pkgdesc="Beautiful network speed test for the terminal, with a hypercar tachometer"
arch=('x86_64' 'aarch64')
url="https://github.com/TarunVishwakarma1/netspd"
license=('MIT')
makedepends=('cargo')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('a8da46179bad5a6b715cd8e1f96acfd50173938545984259920e1914b3d9b5dd')

prepare() {
    cd "$pkgname-$pkgver"
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "$pkgname-$pkgver"
    cargo build --frozen --release
}

check() {
    cd "$pkgname-$pkgver"
    cargo test --frozen --release
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 "target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    "target/release/$pkgname" man > "$pkgname.1"
    install -Dm644 "$pkgname.1" "$pkgdir/usr/share/man/man1/$pkgname.1"
    for shell in bash zsh fish; do
        "target/release/$pkgname" completions "$shell" > "$pkgname.$shell"
    done
    install -Dm644 "$pkgname.bash" "$pkgdir/usr/share/bash-completion/completions/$pkgname"
    install -Dm644 "$pkgname.zsh" "$pkgdir/usr/share/zsh/site-functions/_$pkgname"
    install -Dm644 "$pkgname.fish" "$pkgdir/usr/share/fish/vendor_completions.d/$pkgname.fish"
}
